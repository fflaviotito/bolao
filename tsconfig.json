{
    // Visit https://aka.ms/tsconfig to read more about this file
    "compilerOptions": {
        // File Layout
        "outDir": "./dist",

        // Environment Settings
        "module": "commonjs",
        "target": "esnext",
        "esModuleInterop": true,

        // typeRoots ajuda o VS Code e o tsc, mas o ts-node precisa de ajuda extra
        "typeRoots": ["./node_modules/@types", "./api/types"],

        // Other Outputs
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        // Stricter Typechecking Options
        "noUncheckedIndexedAccess": false,
        "exactOptionalPropertyTypes": true,

        // Recommended Options
        "strict": true,
        "jsx": "react-jsx",
        "verbatimModuleSyntax": false,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    },

    // --- AQUI ESTÁ O SEGREDO DO SUCESSO ---
    // Isso obriga o ts-node a ler os arquivos de definição (.d.ts)
    // que estão dentro das pastas do "include"
    "ts-node": {
        "files": true
    },

    "include": ["api/**/*", "dev-server.ts"]
}
