generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum Papel {
  user
  admin
}

model Usuario {
  id              Int         @id @default(autoincrement())
  nome            String      @db.VarChar(100)
  email           String      @unique @db.VarChar(100)
  senha           String      @db.VarChar(255)
  papel           Papel       @default(user)
  ativo           Boolean     @default(true)
  criadoEm        DateTime    @default(now()) @map("criado_em")
  atualizadoEm    DateTime    @updatedAt @map("atualizado_em")

  tokensRecuperacao       TokenRecuperacao[]
  campeonatosCriados      Campeonato[] @relation("CriadorCampeonato")
  campeonatosAtualizados  Campeonato[] @relation("AtualizadorCampeonato")

  @@map("usuarios")
}

model TokenRecuperacao {
  id          Int         @id @default(autoincrement())
  token       String      @unique @db.VarChar(255)
  expiraEm    DateTime    @map("expira_em")
  criadoEm    DateTime    @default(now()) @map("criado_em")

  usuarioId   Int         @map("usuario_id")
  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_recuperacao")
}

model Campeonato {
  id                Int       @id @default(autoincrement())
  nome              String    @db.VarChar(255)
  divisao           String    @db.VarChar(255)
  ano               Int
  dataInicio        DateTime  @map("data_inicio") @db.Date
  dataFim           DateTime  @map("data_fim") @db.Date
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  criadoPorId       Int       @map("criado_por_id")
  criadoPor         Usuario   @relation("CriadorCampeonato", fields: [criadoPorId], references: [id])

  atualizadoPorId   Int?      @map("atualizado_por_id")
  atualizadoPor     Usuario?  @relation("AtualizadorCampeonato", fields: [atualizadoPorId], references: [id])

  @@map("campeonatos")
}