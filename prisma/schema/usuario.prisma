enum Papel {
  user
  admin
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(100)
  senha        String   @db.VarChar(255)
  papel        Papel    @default(user)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tokensRecuperacao TokenRecuperacao[]

  campeonatosCriados     Campeonato[] @relation("CriadorCampeonato")
  campeonatosAtualizados Campeonato[] @relation("AtualizadorCampeonato")

  estadiosCriados     Estadio[] @relation("CriadorEstadio")
  estadiosAtualizados Estadio[] @relation("AtualizadorEstadio")

  timesCriados     Time[] @relation("CriadorTime")
  timesAtualizados Time[] @relation("AtualizadorTime")

  timesPorCampeonatoCriados     TimesPorCampeonato[] @relation("CriadorTimesPorCampeonato")
  timesPorCampeonatoAtualizados TimesPorCampeonato[] @relation("AtualizadorTimesPorCampeonato")

  rodadasCriadas     Rodada[] @relation("CriadorRodada")
  rodadasAtualizadas Rodada[] @relation("AtualizadorRodada")

  partidasCriadas     Partida[] @relation("CriadorPartida")
  partidasAtualizadas Partida[] @relation("AtualizadorPartida")

  regrasPontuacaoCriadas     RegrasPontuacao[] @relation("CriadorRegraPontuacao")
  regrasPontuacaoAtualizadas RegrasPontuacao[] @relation("AtualizadorRegraPontuacao")

  palpitesPartidasFeitos PalpitePartida[] @relation("PalpitePartidaUsuario")
  palpitesCriados        PalpitePartida[] @relation("CriadorPalpitePartida")
  palpitesAtualizados    PalpitePartida[] @relation("AtualizadorPalpitePartida")

  palpitesClassificacaoFeitos  PalpiteClassificacao[] @relation("PalpiteClassificacaoUsuario")
  palpitesClassificacaoCriados PalpiteClassificacao[] @relation("CriadorPalpiteClassificacao")
  palpitesClassificacaoAtualiz PalpiteClassificacao[] @relation("AtualizadorPalpiteClassificacao")

  @@map("usuarios")
}
